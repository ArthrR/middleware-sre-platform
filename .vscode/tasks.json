{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker: Build",
      "type": "shell",
      "command": "docker",
      "args": ["build", "-t", "${workspaceFolderBasename}:latest", "."],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Terraform: Validate",
      "type": "shell",
      "command": "terraform",
      "args": ["validate"],
      "problemMatcher": []
    },
    {
      "label": "Python: Run",
      "type": "shell",
      "command": "python",
      "args": ["${file}"],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Kubernetes: Apply",
      "type": "shell",
      "command": "kubectl",
      "args": ["apply", "-f", "${file}"]
    }
  ]
}
